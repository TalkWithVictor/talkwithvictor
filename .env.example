# ─── Copia este archivo como .env y rellena los valores ───────────────────────
# NUNCA subas el archivo .env a GitHub (ya está en .gitignore)

# Clave secreta de Flask (pon cualquier texto largo y aleatorio)
SECRET_KEY=cambia-esto-por-algo-muy-largo-y-aleatorio-1234567890

# Tu email de administrador
ADMIN_EMAIL=victor9232005@gmail.com

# Contraseña de tu panel de admin
ADMIN_PASSWORD=tu-contrasena-segura

# URL de tu app (cambia cuando la subas a Render)
APP_URL=http://localhost:5000

# ─── Stripe (opcional al principio, configura cuando quieras cobrar) ───────────
# Encuentra estas claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# IDs de los precios que creas en Stripe
STRIPE_ENROLLMENT_PRICE=price_...
STRIPE_MONTHLY_PRICE=price_...

# Webhook secret (opcional, para validar eventos de Stripe)
STRIPE_WEBHOOK_SECRET=whsec_...
